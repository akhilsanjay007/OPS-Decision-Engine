# Copy to `.env` in `backend/` when running uvicorn locally (not via Docker).
# For Docker Compose, prefer a root `.env` (see repo `.env.example`).

# OpenAI (optional for server startup; ML + RAG work without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Runtime asset paths (absolute, or relative to APP_HOME — use backend/ layout when APP_HOME unset)
# MODEL_PATH=models/priority_stage5_svm_pipeline.joblib
# CHROMA_DIR=data/chroma
# CHROMA_DB_DIR=data/chroma
# CHROMA_USE_RUNTIME_COPY=true
# CHROMA_RUNTIME_DIR=data/chroma_runtime
# CHROMA_RUNTIME_COPY_REFRESH=true
# KB_PATH=data/processed/rag_knowledge_base.jsonl
